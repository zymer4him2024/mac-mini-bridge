rules_version = '2';

// Shomery Firestore security rules.
//
// Schema: users/{uid} owns identity + onboarding state, /config/main, /folders/{slug},
// /folders/{slug}/items/{id}, and /secrets/{id}. Python pipeline writes folder + item docs
// via admin SDK (rules-bypassing). Web client owns user-writable fields only, scoped to an
// explicit allowlist (identity + onboardingCompletedAt).
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwnerByPath(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function userWritableKeys() {
      return [
        'email', 'displayName', 'photoURL', 'createdAt', 'lastSignedInAt',
        'onboardingCompletedAt'
      ];
    }

    function isValidWatchList(v) {
      return v is list && v.size() <= 200;
    }

    function configWritableKeys() {
      return ['priorityWatchSenders', 'digestEnabled', 'telegramEnabled', 'telegramChatId'];
    }

    function isValidNotifications(data) {
      return (!('digestEnabled' in data.keys()) || data.digestEnabled is bool)
        && (!('telegramEnabled' in data.keys()) || data.telegramEnabled is bool)
        && (!('telegramChatId' in data.keys())
            || (data.telegramChatId is string && data.telegramChatId.size() <= 64))
        && (!('telegramEnabled' in data.keys()) || data.telegramEnabled == false
            || ('telegramChatId' in data.keys() && data.telegramChatId.size() > 0));
    }

    function groupWritableKeys() {
      return ['groupId', 'name', 'subjectSlugs', 'createdAt', 'updatedAt'];
    }

    function isValidGroupName(v) {
      return v is string && v.size() > 0 && v.size() <= 50;
    }

    function isValidGroupMembership(v) {
      return v is list && v.size() <= 100;
    }

    match /users/{uid} {
      allow read: if isOwnerByPath(uid);

      // Create on first sign-in: only user-writable fields, exactly the user's own doc.
      allow create: if isOwnerByPath(uid)
        && request.resource.data.keys().hasOnly(userWritableKeys());

      // Subsequent merges: only user-writable fields may change.
      // (Python may add gmail.* etc.; the diff check ignores untouched keys.)
      allow update: if isOwnerByPath(uid)
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(userWritableKeys());

      allow delete: if false;

      match /config/{configId} {
        allow read: if isOwnerByPath(uid);

        // Settings write seam: web may create or update users/{uid}/config/main
        // for the user-writable fields only. Python (admin SDK) bypasses these
        // rules to set every other config field; merge writes from the web side
        // preserve those.
        allow create: if isOwnerByPath(uid)
          && configId == 'main'
          && request.resource.data.keys().hasOnly(configWritableKeys())
          && (!('priorityWatchSenders' in request.resource.data.keys())
              || isValidWatchList(request.resource.data.priorityWatchSenders))
          && isValidNotifications(request.resource.data);

        allow update: if isOwnerByPath(uid)
          && configId == 'main'
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(configWritableKeys())
          && (!('priorityWatchSenders' in request.resource.data.keys())
              || isValidWatchList(request.resource.data.priorityWatchSenders))
          && isValidNotifications(request.resource.data);

        allow delete: if false;
      }

      match /folders/{slug} {
        allow read: if isOwnerByPath(uid);

        // Web client may decrement unreadCount when a user opens an item.
        // Python pipeline is the only writer for everything else; rules
        // confine the web write seam to that single field and require the
        // value to be a non-negative integer.
        allow update: if isOwnerByPath(uid)
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['unreadCount'])
          && request.resource.data.unreadCount is int
          && request.resource.data.unreadCount >= 0;

        allow create, delete: if false; // Python pipeline owns lifecycle.
      }

      match /secrets/{secretId} {
        // Refresh tokens, KMS-wrapped credentials. Never readable by clients.
        allow read, write: if false;
      }

      // Virtual subject groups. Pure-membership records owned by the web
      // client; the Python pipeline does not read or write them. Deleting a
      // group only removes the parent reference — the underlying folders and
      // items are untouched, so unlike /folders and /config we allow delete.
      match /groups/{groupId} {
        allow read: if isOwnerByPath(uid);

        allow create: if isOwnerByPath(uid)
          && request.resource.data.keys().hasOnly(groupWritableKeys())
          && isValidGroupName(request.resource.data.name)
          && isValidGroupMembership(request.resource.data.subjectSlugs);

        allow update: if isOwnerByPath(uid)
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(groupWritableKeys())
          && (!('name' in request.resource.data.diff(resource.data).affectedKeys())
              || isValidGroupName(request.resource.data.name))
          && (!('subjectSlugs' in request.resource.data.diff(resource.data).affectedKeys())
              || isValidGroupMembership(request.resource.data.subjectSlugs));

        allow delete: if isOwnerByPath(uid);
      }
    }

    // Folder items: hoisted to a top-level recursive match so the rule is
    // eligible for collection-group queries (the Feed). The rule expression
    // does not reference any path variable — Firestore requires that for
    // collection-group eligibility — and gates ownership on the doc's
    // denormalized `uid`, which the Python pipeline writes on every item.
    // Subject Detail single-doc reads under
    //   /users/{uid}/folders/{slug}/items/{itemId}
    // also flow through this rule and are owner-gated by the same check.
    match /{path=**}/items/{itemId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid;

      // Web client may set readAt when the user first opens this item.
      // Python pipeline is the only writer for every other field; the rule
      // confines the web write seam to that single key. Ownership is gated
      // on the existing doc's denormalized uid (path-variable-free, so the
      // rule remains eligible for collection-group queries).
      allow update: if request.auth != null
        && request.auth.uid == resource.data.uid
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['readAt']);

      allow create, delete: if false; // Python pipeline owns lifecycle.
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
