# Firebase Web SDK config — public values, safe to expose to the browser.
# Source: Firebase Console → Project settings → Your apps → "shomery-web" Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Local-dev only: when true, the client SDK connects to the Firebase Emulator Suite.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Sentry — leave blank locally to disable. DSN is public.
NEXT_PUBLIC_SENTRY_DSN=

# rag_service base URL (Mac Mini → Cloudflare Tunnel hostname in prod).
# Leave blank to disable the Ask UI; the panel renders an "Ask isn't connected" hint.
NEXT_PUBLIC_RAG_BASE_URL=
